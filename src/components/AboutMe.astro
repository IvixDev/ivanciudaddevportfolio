---
import { useTranslations } from "../i18n/utils";
import { Image } from "astro:assets";
import ivanJapon from "../assets/ivan-japon.webp";
import juegosDeMesa from "../assets/juegos-de-mesa-dados.webp";
import legos from "../assets/legos.webp";

const lang = Astro.currentLocale;
const t = useTranslations(lang);
const about = t("about") as any;
---

<div class="flex flex-col gap-24 w-full">
    <!-- SECCIÓN 1: Perfil Profesional y Origen -->
    <section
        class="grid grid-cols-1 tablet:grid-cols-2 gap-6 tablet:gap-12 w-full tablet:items-center"
    >
        <!-- Título -->
        <div class="order-1 tablet:col-start-1 tablet:row-start-1">
            <h1 class="text-4xl tablet:text-5xl font-bold leading-tight">
                {about.section1_title1}
                <span
                    class="text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 to-purple-500"
                    >Iván Ciudad</span
                >
            </h1>
            <h2
                class="text-xl tablet:text-2xl text-slate-300 font-medium font-source-code mt-4"
            >
                {about.section1_title2}
            </h2>
        </div>

        <!-- Imagen -->
        <div
            class="order-2 tablet:col-start-2 tablet:row-start-1 tablet:row-span-2 flex justify-center"
        >
            <div class="w-full relative group">
                <div
                    class="absolute -inset-1 bg-gradient-to-r from-cyan-400 to-purple-600 rounded-2xl blur opacity-25 group-hover:opacity-50 transition duration-1000 group-hover:duration-200"
                >
                </div>
                <Image
                    src={ivanJapon}
                    alt={about.img_ivan_japon_alt}
                    class="relative w-full h-auto object-cover rounded-2xl shadow-2xl border border-slate-800 aspect-[4/5]"
                    widths={[400, 800]}
                    sizes="(max-width: 768px) 100vw, 50vw"
                    quality={90}
                    loading="eager"
                />
            </div>
        </div>

        <!-- Párrafos -->
        <div
            class="order-3 tablet:col-start-1 tablet:row-start-2 space-y-6 text-slate-400 text-lg leading-relaxed"
        >
            <p>
                <strong class="text-cyan-300">{about.p1_1}</strong>{about.p1_2}
            </p>
            <p>
                <strong class="text-purple-300">{about.p1_3}</strong>
                {about.p1_4}
            </p>
        </div>
    </section>

    <!-- SECCIÓN 2: Pasiones y Desconexión -->
    <section
        class="grid grid-cols-1 tablet:grid-cols-[2fr_3fr] gap-6 tablet:gap-12 w-full tablet:items-center"
    >
        <!-- Título -->
        <h3
            class="order-1 tablet:col-start-2 tablet:row-start-1 text-3xl font-bold text-white flex items-center gap-3"
        >
            <span class="w-8 h-px bg-purple-500 inline-block"></span>
            {about.section2_title}
        </h3>

        <!-- Imagen -->
        <div
            class="order-2 tablet:col-start-1 tablet:row-start-1 tablet:row-span-2 relative group"
        >
            <div
                class="absolute -inset-1 bg-gradient-to-r from-purple-400 to-sky-600 rounded-2xl blur opacity-25 group-hover:opacity-50 transition duration-1000 group-hover:duration-200"
            >
            </div>
            <Image
                src={juegosDeMesa}
                alt={about.img_board_games_alt}
                class="relative w-full h-auto object-cover rounded-2xl shadow-2xl border border-slate-800 aspect-[4/3] tablet:aspect-auto"
                widths={[400, 800]}
                sizes="(max-width: 768px) 100vw, 40vw"
                quality={90}
                loading="eager"
            />
        </div>

        <!-- Párrafos -->
        <div
            class="order-3 tablet:col-start-2 tablet:row-start-2 space-y-4 text-slate-400 text-lg leading-relaxed"
        >
            <p>
                {about.p2_1}<strong class="text-slate-200">{about.p2_2}</strong
                >{about.p2_3}
                <span class="text-slate-200 font-medium">World of Warcraft</span
                >,{" "}
                <span class="text-slate-200 font-medium">The Witcher 3</span>,{
                    " "
                }
                <span class="text-slate-200 font-medium">Dark Souls</span>,{" "}
                <span class="text-slate-200 font-medium">League of Legends</span
                >{about.p2_4}
            </p>
            <p>
                <strong class="text-slate-200">{about.p2_5}</strong>{about.p2_6}
                <span class="text-slate-200 font-medium">{about.p2_7}</span>
                {about.p2_8}
                <span class="text-slate-200 font-medium">{about.p2_9}</span>{
                    about.p2_10
                }
            </p>
            <p>
                {about.p2_11}<span class="text-slate-200 font-medium"
                    >Star Wars</span
                >{about.p2_12}
                <span class="text-slate-200 font-medium"
                    >El Señor de los Anillos</span
                >{about.p2_13}
                <span class="text-slate-200 font-medium"
                    >Juego de Tronos, Breaking Bad, Naruto y Clone Wars</span
                >{about.p2_14}<span class="text-slate-200 font-medium"
                    >Harry Potter</span
                >{about.p2_15}
            </p>
        </div>
    </section>

    <!-- SECCIÓN 3: Construcción y Hardware -->
    <section
        class="grid grid-cols-1 tablet:grid-cols-[3fr_2fr] gap-6 tablet:gap-12 w-full tablet:items-center"
    >
        <!-- Título -->
        <h3
            class="order-1 tablet:col-start-1 tablet:row-start-1 text-3xl font-bold text-white flex items-center gap-3"
        >
            <span class="w-8 h-px bg-cyan-400 inline-block"></span>
            {about.section3_title}
        </h3>

        <!-- Imagen -->
        <div
            class="order-2 tablet:col-start-2 tablet:row-start-1 tablet:row-span-2 relative group"
        >
            <div
                class="absolute -inset-1 bg-gradient-to-r from-cyan-400 to-emerald-500 rounded-2xl blur opacity-25 group-hover:opacity-50 transition duration-1000 group-hover:duration-200"
            >
            </div>
            <Image
                src={legos}
                alt={about.img_legos_alt}
                class="relative w-full h-auto object-cover rounded-2xl shadow-2xl border border-slate-800 aspect-[4/3] tablet:aspect-auto"
                widths={[400, 800]}
                sizes="(max-width: 768px) 100vw, 50vw"
                quality={90}
                loading="lazy"
            />
        </div>

        <!-- Párrafos -->
        <div
            class="order-3 tablet:col-start-1 tablet:row-start-2 space-y-4 text-slate-400 text-lg leading-relaxed"
        >
            <p>
                {about.p3_1}<strong class="text-slate-200">{about.p3_2}</strong
                >{about.p3_3}
            </p>
            <p>
                {about.p3_4}<span class="text-slate-200 font-medium">LEGO</span
                >{about.p3_5}
            </p>
        </div>
    </section>
</div>
