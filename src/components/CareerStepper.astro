---
import { useTranslations } from "../i18n/utils";
import { Image } from "astro:assets";
import trayectoriaImage from "../assets/trayectoria-profesional.webp";
import {
    IconBuildingSkyscraper,
    IconDownload,
    IconSchool,
    IconCode,
    IconUsers,
} from "@tabler/icons-react";

const TECHNOLOGIES = [
    {
        category: "Frontend",
        items: [
            "IA",
            "Claude",
            "Next.js",
            "React",
            "Angular",
            "TypeScript",
            "Tailwind",
        ],
    },
    {
        category: "Backend",
        items: ["Node.js", "Java", "Spring Boot", "MySQL", "Google Cloud"],
    },
    {
        category: "Herramientas",
        items: ["Git", "JIRA", "Gitflow", "Docker", "Figma"],
    },
];

const lang = Astro.currentLocale;
const t = useTranslations(lang);
const career = t("career") as any;
const experiences = t("experiences") as any[];
const educations = t("educations") as any[];
const softskills = t("softskills") as any[];
const techCategories = t("tech_categories") as any;
---

<div class="relative w-full max-w-5xl mx-auto px-4 py-8 overflow-hidden">
    <!-- Background Blobs -->
    <div
        class="absolute -top-20 -right-20 w-80 h-80 bg-purple-500/10 rounded-full blur-3xl -z-10 pointer-events-none"
    >
    </div>
    <div
        class="absolute -bottom-20 -left-20 w-80 h-80 bg-sky-500/10 rounded-full blur-3xl -z-10 pointer-events-none"
    >
    </div>

    <header
        class="mb-16 relative z-10 flex flex-col md:flex-row items-center gap-8 md:gap-12"
    >
        <div class="flex-1 text-center md:text-left">
            <h2 class="text-4xl md:text-5xl font-bold mb-4 text-white">
                {career.title1}
                <span
                    class="bg-gradient-to-r from-sky-400 to-purple-400 bg-clip-text text-transparent"
                    >{career.title2}</span
                >
            </h2>
            <p
                class="text-slate-400 text-base md:text-lg leading-relaxed max-w-xl mx-auto md:mx-0 mb-8"
            >
                {career.description}
            </p>

            <div
                class="flex flex-wrap items-center justify-center md:justify-start gap-6"
            >
                <a
                    href="/CV_IvanCiudadEspinar.pdf"
                    download
                    class="group relative inline-flex items-center justify-center px-6 py-2.5 text-sm font-bold text-white transition-all duration-200 bg-gradient-to-r from-sky-500 to-purple-600 rounded-full hover:scale-105 hover:shadow-lg hover:shadow-sky-500/25 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-sky-500 focus:ring-offset-slate-900 w-full sm:w-auto"
                >
                    <span
                        class="absolute inset-0 w-full h-full rounded-full opacity-0 group-hover:opacity-20 bg-white transition-opacity"
                    ></span>
                    <IconDownload className="mr-2" size={18} />
                    {career.download_cv}
                </a>
                <p class="text-xs text-slate-500 font-medium">
                    {career.last_update}
                </p>
            </div>
        </div>

        <div class="w-full max-w-[280px] md:max-w-[320px] relative group">
            <div
                class="absolute -inset-1 bg-gradient-to-r from-sky-400 to-purple-600 rounded-2xl blur opacity-20 group-hover:opacity-40 transition duration-1000"
            >
            </div>
            <Image
                src={trayectoriaImage}
                alt={career.img_career_alt}
                class="relative w-full h-auto object-cover rounded-2xl shadow-2xl border border-slate-800"
                widths={[320, 640]}
                sizes="(max-width: 768px) 280px, 320px"
                quality={90}
            />
        </div>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 relative z-10">
        <!-- EXPERIENCE COLUMN -->
        <div>
            <div class="mb-8 flex items-center gap-3">
                <div
                    class="p-2 bg-sky-500/10 rounded-lg border border-sky-500/20"
                >
                    <IconBuildingSkyscraper
                        className="text-sky-500"
                        size={24}
                    />
                </div>
                <h3 class="text-xl font-bold text-white">
                    {career.experience_title}
                </h3>
            </div>

            <div
                class="relative ml-6 pl-4 border-l-2 border-slate-800 space-y-12"
            >
                {
                    experiences.map((exp, index) => (
                        <div class="relative group">
                            <div
                                class={`absolute -left-[21px] top-6 w-3 h-3 rounded-full ring-4 ring-slate-900 ${
                                    index === 0
                                        ? "bg-sky-500 shadow-[0_0_12px_rgba(14,165,233,0.5)]"
                                        : "bg-slate-600 group-hover:bg-sky-400 transition-colors"
                                }`}
                            />
                            <div
                                class={`bg-slate-900/50 border border-slate-800 p-6 rounded-2xl transition-all duration-300 hover:border-sky-500/30 hover:shadow-lg ${
                                    index === 0
                                        ? "shadow-[0_0_40px_-10px_rgba(14,165,233,0.15)] border-sky-500/20"
                                        : ""
                                }`}
                            >
                                <div class="flex flex-col gap-2 mb-4">
                                    <span class="text-xs font-bold tracking-wide text-sky-400">
                                        {exp.date}
                                    </span>
                                    <h3 class="text-lg font-bold text-white group-hover:text-sky-400 transition-colors">
                                        {exp.title}
                                    </h3>
                                    <div class="text-sm font-medium text-slate-400">
                                        {exp.company}
                                    </div>
                                </div>
                                <p class="text-sm text-slate-300 mb-5 leading-relaxed">
                                    {exp.description}
                                </p>
                                <div class="flex flex-wrap gap-2">
                                    {exp.tags?.map((tag: string) => (
                                        <span class="px-2.5 py-1 text-xs font-medium rounded-md bg-slate-800 text-slate-300 border border-slate-700">
                                            {tag}
                                        </span>
                                    ))}
                                </div>
                            </div>
                        </div>
                    ))
                }
            </div>
        </div>

        <!-- EDUCATION COLUMN -->
        <div>
            <div class="mb-8 flex items-center gap-3">
                <div
                    class="p-2 bg-purple-500/10 rounded-lg border border-purple-500/20"
                >
                    <IconSchool className="text-purple-500" size={24} />
                </div>
                <h3 class="text-xl font-bold text-white">
                    {career.education_title}
                </h3>
            </div>

            <div
                class="relative ml-6 pl-4 border-l-2 border-slate-800 space-y-12"
            >
                {
                    educations.map((edu, index) => (
                        <div class="relative group">
                            <div
                                class={`absolute -left-[21px] top-6 w-3 h-3 rounded-full ring-4 ring-slate-900 ${
                                    index === 0
                                        ? "bg-purple-500 shadow-[0_0_12px_rgba(168,85,247,0.5)]"
                                        : "bg-slate-600 group-hover:bg-purple-400 transition-colors"
                                }`}
                            />
                            <div
                                class={`bg-slate-900/50 border border-slate-800 p-6 rounded-2xl transition-all duration-300 hover:border-purple-500/30 hover:shadow-lg ${
                                    index === 0
                                        ? "shadow-[0_0_40px_-10px_rgba(168,85,247,0.15)] border-purple-500/20"
                                        : ""
                                }`}
                            >
                                <div class="flex flex-col gap-2 mb-4">
                                    <span class="text-xs font-bold tracking-wide text-purple-400">
                                        {edu.date}
                                    </span>
                                    <h3 class="text-lg font-bold text-white group-hover:text-purple-400 transition-colors">
                                        {edu.title}
                                    </h3>
                                    <div class="text-sm font-medium text-slate-400">
                                        {edu.institution}
                                    </div>
                                </div>
                                <p class="text-sm text-slate-300 leading-relaxed">
                                    {edu.description}
                                </p>
                            </div>
                        </div>
                    ))
                }
            </div>

            <!-- TECH & SOFT SKILLS (To fill space) -->
            <div class="mt-16 grid grid-cols-1 gap-12">
                <!-- TECH SKILLS -->
                <div>
                    <div class="mb-6 flex items-center gap-3">
                        <div
                            class="p-2 bg-emerald-500/10 rounded-lg border border-emerald-500/20"
                        >
                            <IconCode className="text-emerald-500" size={20} />
                        </div>
                        <h3 class="text-lg font-bold text-white">
                            {career.tech_stack_title}
                        </h3>
                    </div>
                    <div class="space-y-4">
                        {
                            TECHNOLOGIES.map((tech) => (
                                <div>
                                    <h4 class="text-xs font-bold text-slate-500 uppercase tracking-widest mb-2">
                                        {techCategories[tech.category] ||
                                            tech.category}
                                    </h4>
                                    <div class="flex flex-wrap gap-2">
                                        {tech.items.map((item) => (
                                            <span class="px-2 py-1 text-xs rounded bg-slate-900 border border-slate-800 text-slate-300">
                                                {item}
                                            </span>
                                        ))}
                                    </div>
                                </div>
                            ))
                        }
                    </div>
                </div>

                <!-- SOFT SKILLS -->
                <div>
                    <div class="mb-6 flex items-center gap-3">
                        <div
                            class="p-2 bg-amber-500/10 rounded-lg border border-amber-500/20"
                        >
                            <IconUsers className="text-amber-500" size={20} />
                        </div>
                        <h3 class="text-lg font-bold text-white">
                            {career.soft_skills_title}
                        </h3>
                    </div>
                    <div class="flex flex-wrap gap-2">
                        {
                            softskills.map((skill) => (
                                <span class="px-3 py-1.5 text-xs font-medium rounded-full bg-slate-900 border border-slate-800 text-slate-300">
                                    {skill}
                                </span>
                            ))
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
