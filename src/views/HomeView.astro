---
import Layout from "../layouts/Layout.astro";
import { seoMapper } from "../helpers/seo.helper";
import { socialMediaLinks } from "../content/layout.consts";
import ScrollReveal from "../components/ScrollReveal";
import { IconArrowRight } from "@tabler/icons-react";
import { Image } from "astro:assets";
import ivanHeroImg from "../assets/ivan-ciudad-hero.webp";
import sobreMiImg from "../assets/ivan-japon.webp";
import proyectosImg from "../assets/proyectos-buscaminas.webp";
import trayectoriaImg from "../assets/trayectoria-profesional.webp";
import { useTranslations } from "../i18n/utils";

const lang = Astro.currentLocale;
const t = useTranslations(lang);

const title = t("home.title");
const description = t("home.description");
const url = t("home.image_url");
const image = t("home.image_url");

const infoSeo = seoMapper(
  title,
  description,
  url,
  image,
  `${t("home.image_alt")}`,
);

const schema = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Iván Ciudad Espinar",
  url: url,
  image: image,
  sameAs: socialMediaLinks
    .filter((link) => link.href.startsWith("http"))
    .map((link) => link.href),
  jobTitle: "Software Developer",
  description: description,
};
---

<Layout infoSeo={infoSeo}>
  <script
    is:inline
    type="application/ld+json"
    set:html={JSON.stringify(schema)}
  />
  <main class="flex flex-col items-center w-full gap-12 laptop:gap-20">
    <!-- Hero Section -->
    <section
      class="flex flex-col-reverse tablet:flex-row justify-between items-center gap-12 w-full pt-10"
    >
      <div class="flex flex-col gap-6 max-w-2xl">
        <h1
          class="text-4xl tablet:text-5xl laptop:text-6xl font-bold leading-tight"
        >
          {t("home.soy_ivan")}<span
            class="text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 to-purple-500"
            >Iván Ciudad</span
          >, <br />
          {t("home.software_developer")}
          <br />
          <span class="text-slate-300">{t("home.telematics_engineer")}</span>.
        </h1>
        <h2
          class="text-xl tablet:text-2xl text-slate-400 max-w-xl leading-relaxed"
        >
          {t("home.welcome_subtitle")}
        </h2>
      </div>
      <div class="relative group">
        <div
          class="absolute -inset-1 bg-gradient-to-r from-cyan-400 to-purple-600 rounded-full blur opacity-25 group-hover:opacity-50 transition duration-1000 group-hover:duration-200"
        >
        </div>
        <Image
          src={ivanHeroImg}
          alt={t("home.image_alt")}
          class="relative w-48 h-48 tablet:w-64 tablet:h-64 laptop:w-80 laptop:h-80 object-cover rounded-full border-4 border-slate-900 shadow-2xl"
          loading="eager"
          fetchpriority="high"
          widths={[400, 800]}
          sizes="(max-width: 768px) 192px, (max-width: 1024px) 256px, 320px"
          quality={80}
        />
      </div>
    </section>

    <hr class="w-full border-t border-slate-800/60" />

    <!-- Focus Section -->
    <ScrollReveal client:visible delay={0.2}>
      <section
        class="flex flex-col gap-4 w-full max-w-4xl text-center items-center"
      >
        <span
          class="text-cyan-400 font-mono text-base font-bold tracking-widest uppercase mb-2"
          >{t("home.about_web")}</span
        >
        <h3 class="text-3xl tablet:text-4xl font-bold">
          {t("home.what_find")}
        </h3>
        <p
          class="text-lg text-slate-300 leading-relaxed max-w-3xl"
          set:html={t("home.what_find_desc")}
        />
      </section>
    </ScrollReveal>

    <!-- Content Grid -->
    <section class="grid grid-cols-1 tablet:grid-cols-3 gap-6 w-full">
      <!-- Card 1: Proyectos -->
      <ScrollReveal client:visible delay={0.1}>
        <a
          href={t("home.projects_url")}
          class="group relative flex flex-col gap-4 p-6 rounded-2xl bg-slate-800/30 border border-white/5 hover:border-purple-500/30 backdrop-blur-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-lg hover:shadow-purple-500/10 overflow-hidden h-full"
        >
          <div
            class="absolute inset-0 bg-gradient-to-b from-transparent to-slate-900/90 z-10 pointer-events-none"
          >
          </div>
          <div class="h-48 w-full overflow-hidden rounded-xl mb-2">
            <Image
              src={proyectosImg}
              alt={t("home.projects_img_alt")}
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
              widths={[400, 800]}
              sizes="(max-width: 1024px) 90vw, 30vw"
              quality={80}
            />
          </div>
          <div class="z-20 flex flex-col gap-2 flex-1">
            <h4
              class="text-2xl font-bold group-hover:text-purple-400 transition-colors"
            >
              {t("home.my_projects")}
            </h4>
            <p class="text-slate-400 text-sm leading-relaxed">
              {t("home.my_projects_desc")}
            </p>
            <span
              class="mt-auto text-purple-400 text-sm font-medium flex items-center gap-2"
            >
              {t("home.view_portfolio")}
              <IconArrowRight
                className="w-4 h-4 group-hover:translate-x-1 transition-transform"
              />
            </span>
          </div>
        </a>
      </ScrollReveal>

      <!-- Card 2: Trayectoria -->
      <ScrollReveal client:visible delay={0.2}>
        <a
          href={t("home.career_url")}
          class="group relative flex flex-col gap-4 p-6 rounded-2xl bg-slate-800/30 border border-white/5 hover:border-green-500/30 backdrop-blur-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-lg hover:shadow-green-500/10 overflow-hidden h-full"
        >
          <div
            class="absolute inset-0 bg-gradient-to-b from-transparent to-slate-900/90 z-10 pointer-events-none"
          >
          </div>
          <div class="h-48 w-full overflow-hidden rounded-xl mb-2">
            <Image
              src={trayectoriaImg}
              alt={t("home.career_img_alt")}
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
              widths={[400, 800]}
              sizes="(max-width: 1024px) 90vw, 30vw"
              quality={80}
            />
          </div>
          <div class="z-20 flex flex-col gap-2 flex-1">
            <h4
              class="text-2xl font-bold group-hover:text-green-400 transition-colors"
            >
              {t("home.career")}
            </h4>
            <p class="text-slate-400 text-sm leading-relaxed">
              {t("home.career_desc")}
            </p>
            <span
              class="mt-auto text-green-400 text-sm font-medium flex items-center gap-2"
            >
              {t("home.view_cv")}
              <IconArrowRight
                className="w-4 h-4 group-hover:translate-x-1 transition-transform"
              />
            </span>
          </div>
        </a>
      </ScrollReveal>

      <!-- Card 3: Sobre Mi -->
      <ScrollReveal client:visible delay={0.3}>
        <a
          href={t("home.about_url")}
          class="group relative flex flex-col gap-4 p-6 rounded-2xl bg-slate-800/30 border border-white/5 hover:border-cyan-500/30 backdrop-blur-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-lg hover:shadow-cyan-500/10 overflow-hidden h-full"
        >
          <div
            class="absolute inset-0 bg-gradient-to-b from-transparent to-slate-900/90 z-10 pointer-events-none"
          >
          </div>
          <div class="h-48 w-full overflow-hidden rounded-xl mb-2">
            <Image
              src={sobreMiImg}
              alt={t("home.about_img_alt")}
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
              widths={[400, 800]}
              sizes="(max-width: 1024px) 90vw, 30vw"
              quality={80}
            />
          </div>
          <div class="z-20 flex flex-col gap-2 flex-1">
            <h4
              class="text-2xl font-bold group-hover:text-cyan-400 transition-colors"
            >
              {t("home.about_me")}
            </h4>
            <p class="text-slate-400 text-sm leading-relaxed">
              {t("home.about_me_desc")}
            </p>
            <span
              class="mt-auto text-cyan-400 text-sm font-medium flex items-center gap-2"
            >
              {t("home.read_more")}
              <IconArrowRight
                className="w-4 h-4 group-hover:translate-x-1 transition-transform"
              />
            </span>
          </div>
        </a>
      </ScrollReveal>
    </section>
  </main>
</Layout>
